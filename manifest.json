{
  "manifest_version": 3,
  "name": "ClickStyle",
  "version": "1.0.0",
  "description": "Click any element to edit its CSS styles instantly. The fastest way to tweak styles without DevTools.",
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}